// Simple Roster Plus — data model (v1 foundation)
// Calendar semantics use PostgreSQL DATE; interpret "business day" with Organization.timeZone (IANA).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  /// IANA timezone, e.g. America/Toronto or UTC. Default for child locations and used directly when
  /// a location does not provide its own override.
  timeZone  String   @default("UTC")

  // --- Billing & lifecycle (operator console; see docs/OPERATOR_CONSOLE.md) ---
  // Stripe is the source of truth for money; these columns MIRROR Stripe so the operator
  // console can render lists and trigger alerts without a Stripe round-trip per row. They are
  // populated/maintained by Stripe webhooks, never edited by tenant-facing code.
  /// Stripe customer id (`cus_...`). Null until the org is linked to Stripe.
  stripeCustomerId     String?  @unique
  /// Stripe subscription id (`sub_...`). Null while on trial/demo or unsubscribed.
  stripeSubscriptionId String?  @unique
  /// Plan slug shown in the console, e.g. `trial` | `starter` | `pro`. Null = no plan yet.
  plan                 String?
  /// Mirror of the Stripe subscription status, e.g. `active` | `trialing` | `past_due` | `canceled`.
  subscriptionStatus   String?
  /// Normalized monthly recurring revenue in cents for this org, mirrored from the Stripe
  /// subscription (yearly plans divided by 12). Exact MRR source; falls back to a plan→price
  /// estimate only when null. Maintained by Stripe webhooks.
  mrrCents             Int?
  /// End of the current paid period (Stripe `current_period_end`). Drives renewal display.
  currentPeriodEnd     DateTime?
  /// When the free trial ends. Drives the "trials ending" overview metric.
  trialEndsAt          DateTime?
  /// Seeded sandbox org (GTM demo funnel). See AGENT_CONTEXT_GTM_AUTH_PRICING.md.
  isDemo               Boolean  @default(false)
  /// When a demo sandbox should be auto-reclaimed.
  demoExpiresAt        DateTime?
  /// Operator suspended this org (non-payment, abuse). Non-null = access blocked.
  suspendedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          AppUser[]
  staff          Staff[]
  departments    Department[]
  staffRoles     StaffRole[]
  shiftTemplates ShiftTemplate[]
  rosterWeeks    RosterWeek[]
  publicHolidays PublicHoliday[]
  appSettings    AppSetting[]
  locations      Location[]
  devices               Device[]
  attendanceLogs        AttendanceLog[]
  attendanceDeviceClocks AttendanceDeviceClock[]
}

/// A physical (or logical) site under an organization. Single-location orgs get one default
/// location automatically; multi-site orgs (e.g. supermarket chains) can have many.
model Location {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  /// Optional IANA override for this location; falls back to Organization.timeZone when null.
  timeZone       String?
  /// ISO 3166-1 alpha-2 holiday calendar for this location (e.g. `CA`, `GB`).
  holidayCountryCode     String?
  /// Optional first-level subdivision code for the holiday calendar (e.g. `ON`, `ENG`).
  holidaySubdivisionCode String?
  /// Exactly one location per organization should be marked default.
  isDefault      Boolean      @default(false)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  staff          Staff[]
  rosterWeeks    RosterWeek[]
  devices        Device[]
  publicHolidays PublicHoliday[]
  attendanceLogs AttendanceLog[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

/// How we expect to talk to a device. ADMS push is the typical ZKTeco terminal flow where the
/// device calls our `/iclock/*` endpoints; pull TCP is when we initiate a socket to the device
/// (port 4370 by default) and read users/punches on demand.
enum DeviceConnectionMode {
  adms_push
  pull_tcp
}

/// Attendance / access device (e.g. a ZKTeco terminal) attached to a single location.
model Device {
  id                   String               @id @default(cuid())
  organizationId       String
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId           String
  location             Location             @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name                 String
  /// Free-text legacy identifier (kept for backward compatibility). Prefer `serialNumber` for
  /// new ZKTeco terminals — that's what arrives on `/iclock/cdata` callbacks as `SN=...`.
  identifier           String?
  /// Manufacturer serial number reported by the device. Unique within an organization when set
  /// so ADMS callbacks can route punches to a single Device row.
  serialNumber         String?
  /// Marketing model name, e.g. `K40`, `MB360`, `SpeedFace-V5L`.
  model                String?
  /// Firmware string the device reports. Surfaced for support; not used for routing.
  firmwareVersion      String?
  connectionMode       DeviceConnectionMode @default(adms_push)
  /// Required for `pull_tcp`; informational for `adms_push`.
  ipAddress            String?
  /// ZKTeco terminals default to 4370 for the pull SDK; ADMS uses HTTP and ignores this.
  port                 Int?
  /// Hash of the comm key the device sends with every ADMS request. Treat as a secret.
  commPasswordHash     String?
  /// Soft-disable: when false, ADMS callbacks for this device should be ignored and pull
  /// jobs should skip it. Replaces "delete the device" for terminals being temporarily removed.
  enabled              Boolean              @default(true)
  /// Last time we saw any contact (ADMS callback succeeded or pull completed). Drives the
  /// online/idle/offline pill on the devices list.
  lastSeenAt           DateTime?
  /// Optional IANA override for this device. Falls back to Location.timeZone, then
  /// Organization.timeZone. Useful when a device's onboard clock is set to a different zone
  /// than the location it serves.
  timeZone             String?
  /// Cached counts from the most recent successful sync. Refreshed by the sync job; surfaced
  /// in the UI so operators can see device capacity at a glance.
  lastUserCount        Int?
  lastFingerprintCount Int?
  lastPunchCount       Int?
  /// Free-text operator notes ("the one by the loading dock", "replaced 2026-01-12"). Not
  /// surfaced to the device — purely for humans browsing the list.
  notes                String?
  /// Soft delete: when set, the device is hidden from the default list and ignored by the
  /// ADMS/pull pipelines. The row stays so historical AttendanceLog references remain
  /// resolvable. Hard purge will be a separate "Recently removed" workflow.
  deletedAt            DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  attendanceLogs AttendanceLog[]

  /// NOTE: these uniques apply to soft-deleted rows too — until the "Recently removed"
  /// workflow exists, an operator who soft-deletes a device will need to rename the row to
  /// free the (locationId, name) / (organizationId, serialNumber) slots before re-adding.
  @@unique([locationId, name])
  @@unique([organizationId, serialNumber])
  @@index([locationId])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
}

model AppUser {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  passwordHash   String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  decidedDayOffs   StaffDayOff[]           @relation("DayOffDecidedBy")
  decidedVacations StaffVacation[]         @relation("VacationDecidedBy")
  createdPunches   AttendanceLog[]         @relation("PunchCreatedBy")
  correctedPunches AttendanceLog[]         @relation("PunchCorrectedBy")
  decidedOverrides AttendanceDayOverride[] @relation("OverrideDecidedBy")

  @@unique([organizationId, email])
  @@index([organizationId])
}

/// Org-wide reporting group (HR, Accounting, Front of House). Not the same as job role.
model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  sortOrder      Int          @default(0)
  staff          Staff[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

/// Job title / function (Accountant, Server, HR Manager). Org-wide list for consistency.
model StaffRole {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  sortOrder      Int          @default(0)
  staff          Staff[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Staff {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Primary location this staff member belongs to. Required; backfilled to the org's default
  /// location during the locations migration.
  locationId     String
  location       Location     @relation(fields: [locationId], references: [id])
  firstName      String
  lastName       String
  email          String?
  role           String?
  roleId         String?
  staffRole      StaffRole?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  /// User id on the location's attendance device. Unique within a location, not across the org,
  /// so two locations with separate devices can each have a "5".
  deviceUserId   String?
  punchExempt         Boolean      @default(false)
  /// Synced with archive: false when `archivedAt` is set (no longer with the company).
  isActive            Boolean      @default(true)
  /// When set, staff has left; attendance and roster only show data at or before this instant.
  archivedAt          DateTime?
  /// Set only at creation. Test/dummy rows may be deleted when they have no linked data.
  isTestUser          Boolean      @default(false)
  /// When true, attendance only — omitted from the roster grid.
  excludeFromRoster   Boolean      @default(false)
  dateOfBirth         DateTime?    @db.Date
  startDate           DateTime?    @db.Date
  contactNumber  String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  dayOffs             StaffDayOff[]
  vacations           StaffVacation[]
  sickLeaves          StaffSickLeave[]
  rosterEntries       RosterEntry[]
  attendanceLogs      AttendanceLog[]
  attendanceOverrides AttendanceDayOverride[]

  @@unique([locationId, deviceUserId])
  @@index([organizationId])
  @@index([organizationId, sortOrder])
  @@index([locationId])
}

/// Status shared by leave requests (vacation + day off). `requested` rows sit in the Requests
/// inbox waiting on a supervisor; `approved` rows actively block roster cells; `denied` rows
/// stay around as audit trail and never block.
enum LeaveRequestStatus {
  requested
  approved
  denied
}

model StaffDayOff {
  id              String             @id @default(cuid())
  staffId         String
  staff           Staff              @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date            DateTime           @db.Date
  status          LeaveRequestStatus @default(approved)
  reason          String?
  decidedByUserId String?
  decidedBy       AppUser?           @relation("DayOffDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decidedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([staffId, date])
  @@index([staffId])
  @@index([staffId, status])
}

/// Approved-or-pending vacation block for a staff member. Replaces the old
/// `Staff.vacationStart/End` columns so an organization can record multiple ranges and have a
/// real approval audit trail. Roster blocking honors `approved` rows only.
model StaffVacation {
  id              String             @id @default(cuid())
  staffId         String
  staff           Staff              @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startDate       DateTime           @db.Date
  endDate         DateTime           @db.Date
  status          LeaveRequestStatus @default(requested)
  reason          String?
  decidedByUserId String?
  decidedBy       AppUser?           @relation("VacationDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decidedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([staffId])
  @@index([staffId, status])
}

enum SickLeaveStatus {
  requested
  approved
  denied
}

model StaffSickLeave {
  id        String          @id @default(cuid())
  staffId   String
  staff     Staff           @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startDate DateTime        @db.Date
  endDate   DateTime        @db.Date
  status    SickLeaveStatus @default(requested)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([staffId])
}

model ShiftTemplate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  startTime      String
  endTime        String
  /// Unpaid break deducted from scheduled hours (e.g. 15 for a quarter-hour lunch).
  unpaidBreakMinutes Int      @default(0)
  color          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  rosterEntries RosterEntry[]

  @@index([organizationId])
}

enum RosterWeekStatus {
  draft
  published
}

model RosterWeek {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Location this roster belongs to. Required; backfilled to the org's default location during
  /// the locations migration.
  locationId     String
  location       Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  weekStart      DateTime         @db.Date
  status         RosterWeekStatus @default(draft)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  entries RosterEntry[]

  @@unique([locationId, weekStart])
  @@index([organizationId])
  @@index([locationId])
}

model RosterEntry {
  id              String         @id @default(cuid())
  rosterWeekId    String
  rosterWeek      RosterWeek     @relation(fields: [rosterWeekId], references: [id], onDelete: Cascade)
  staffId         String
  staff           Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date            DateTime       @db.Date
  shiftTemplateId String?
  shiftTemplate   ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)
  position        String?
  notes           String?

  @@unique([rosterWeekId, staffId, date])
  @@index([rosterWeekId])
  @@index([staffId])
}

model PublicHoliday {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId     String
  location       Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  date           DateTime     @db.Date
  name           String
  source         String       @default("manual")
  stationClosed  Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([locationId, date])
  @@index([organizationId])
  @@index([locationId])
}

model AppSetting {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key            String
  value          String       @db.Text

  @@unique([organizationId, key])
  @@index([organizationId])
}

/// Direction of a punch event. Two-state for v1 manual entry; future device sources may
/// surface additional types (e.g. break in/out) but we'll add those when a device pipeline
/// actually emits them rather than speculating now.
enum PunchType {
  in
  out
}

/// Where a punch came from. `manual` is the only writable source in v1. The `device_*`
/// values are reserved so the column type is stable when the ADMS / pull pipelines land.
enum PunchSource {
  manual
  device_adms
  device_pull
}

/// How the staff member verified themselves at the device — fingerprint, face, card, PIN,
/// etc. This is the ZKTeco "verify mode" mapped to a stable label set. Null when unknown
/// or not applicable (every manual punch is null because a supervisor entered it on the
/// staff's behalf — there's no biometric to record). `other` is the catch-all for device
/// codes we haven't mapped yet so unrecognized values still ingest cleanly.
enum PunchVerifyMethod {
  fingerprint
  face
  card
  password
  palm
  other
}

/// One row per real-world clock event. `punchAt` is a UTC instant (not `@db.Date`), so the
/// org/location timezone is only applied when bucketing punches into "what calendar day"
/// — never on write.
///
/// `staffId` is nullable to leave room for future device punches that arrive un-mapped to a
/// known staff member; for v1 manual entry the API requires it.
///
/// Edits update `punchAt` in place but record the original time in `originalPunchAt` so the
/// UI can surface a `CORRECTED` pill (and an auditor can compare). A delete-and-recreate
/// path also exists for cases where it's easier than editing.
model AttendanceLog {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId        String
  location          Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  staffId           String?
  staff             Staff?       @relation(fields: [staffId], references: [id], onDelete: SetNull)
  deviceId          String?
  device            Device?      @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  punchAt           DateTime
  punchType         PunchType
  source            PunchSource  @default(manual)
  /// How the staff verified at the device (fingerprint / face / card / password / palm).
  /// Null for `manual` source punches and for device punches whose verify mode we
  /// couldn't map. Kept on the row (not derived from `source`) because a single device
  /// can emit any method per punch.
  verifyMethod      PunchVerifyMethod?
  note              String?
  /// Original `punchAt` value before the most recent edit. Null when the row has never been
  /// corrected. Lets the UI render a `CORRECTED` pill with the previous time in a tooltip.
  originalPunchAt   DateTime?
  createdByUserId   String?
  createdBy         AppUser?     @relation("PunchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  correctedByUserId String?
  correctedBy       AppUser?     @relation("PunchCorrectedBy", fields: [correctedByUserId], references: [id], onDelete: SetNull)
  correctedAt       DateTime?
  /// Terminal user id when `staffId` is null (unmapped punch) or canonical id from staff match.
  deviceUserId      String?
  /// Raw ATTLOG timestamp string before clock normalization (support / audit).
  deviceRawTimestamp String?
  /// Server time when the ADMS ingest request was accepted.
  ingestReceivedAt  DateTime?
  /// Milliseconds added to naive device parse to form `punchAt` (median drift correction).
  clockOffsetMsApplied Int?
  /// warmup | learned_offset | apply_disabled | no_serial | parse_fallback | …
  clockNormalizeReason String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([locationId, punchAt])
  @@index([staffId, punchAt])
  @@index([organizationId, punchAt])
  @@index([deviceId])
  @@index([deviceUserId, punchAt])
}

/// Learned clock drift per ZKTeco serial within an organization (ADMS SN). Conservative ADMS-only learning.
model AttendanceDeviceClock {
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deviceSerial       String
  offsetMs           Int      @default(0)
  isCalibrated       Boolean  @default(false)
  pendingDeltasJson  String   @default("[]")
  calibrationSamples Int      @default(0)
  updatedAt          DateTime @updatedAt

  @@id([organizationId, deviceSerial])
  @@index([organizationId])
}

/// Manual supervisor call on a single calendar day for a single staff member when the
/// punches don't tell the story (forgot to clock out, sick day called in, etc.). Mirrors the
/// `StaffDayOff` shape — same `(staffId, date)` unique, same audit fields — so it reads as a
/// sibling concept.
///
/// We deliberately stop at two states: `present` and `absent`. Excused absences (vacation,
/// approved day off, sick leave, station-closed holiday) are already modeled by the leave
/// tables and `PublicHoliday.stationClosed`, so layering an `excused` value here would be a
/// second source of truth for the same question.
enum AttendanceOverrideStatus {
  present
  absent
}

model AttendanceDayOverride {
  id              String                   @id @default(cuid())
  staffId         String
  staff           Staff                    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date            DateTime                 @db.Date
  status          AttendanceOverrideStatus
  /// Free-text reason surfaced next to the cell, e.g. "Bus broke down" — used as a hint to
  /// the next supervisor reviewing the week, not parsed by code.
  lateReason      String?
  note            String?
  decidedByUserId String?
  decidedBy       AppUser?                 @relation("OverrideDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decidedAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@unique([staffId, date])
  @@index([staffId])
  @@index([staffId, date])
}

// ============================================================================
// Operator console (platform admin plane). See docs/OPERATOR_CONSOLE.md.
//
// These tables are the OPERATOR identity + audit store. They are intentionally
// separate from the tenant-facing `AppUser` (customers) and carry no
// `organizationId` — operators act ACROSS all tenants. Access to anything that
// reads these is gated behind the operator auth boundary (`lib/ops/*`).
// ============================================================================

/// Coarse capability tier for an operator. Enforced in `lib/ops` before any
/// privileged action. `readonly` can view everything; `support` adds
/// impersonation/notes; `billing` adds refunds/plan changes; `superadmin` adds
/// suspend/delete and operator management.
enum OperatorRole {
  readonly
  support
  billing
  superadmin
}

/// An internal SR+ staff member allowed onto the platform control plane. Auth
/// proves *who you are*; a row here proves *you may operate the plane*
/// (defense in depth). `clerkUserId` is reserved for the future dedicated
/// operator Clerk app; today login uses `passwordHash` (custom JWT, mirroring
/// the pre-Clerk customer auth).
model OperatorUser {
  id           String       @id @default(cuid())
  email        String       @unique
  /// Null once the operator Clerk app is adopted; today holds the bcrypt hash.
  passwordHash String?
  /// Reserved: subject id from the dedicated operator Clerk application.
  clerkUserId  String?      @unique
  role         OperatorRole @default(readonly)
  /// Non-null = access revoked without deleting the audit trail linkage.
  disabledAt   DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  auditLogs OperatorAuditLog[]
}

/// Immutable record of every operator action. Append-only by convention; the
/// console never updates or deletes rows. `metadata` carries before/after and a
/// human reason for sensitive actions (suspend, refund, impersonate).
model OperatorAuditLog {
  id             String       @id @default(cuid())
  operatorUserId String
  operator       OperatorUser @relation(fields: [operatorUserId], references: [id], onDelete: Cascade)
  /// Dotted action key, e.g. `org.suspend`, `billing.refund`, `impersonate.start`, `auth.login`.
  action         String
  /// Entity class the action targeted, e.g. `organization`, `appUser`, `device`, `session`.
  targetType     String
  targetId       String?
  /// Affected tenant when applicable, for per-org audit filtering.
  organizationId String?
  /// Free-form JSON: { before, after, reason, ip, ... }. Stored as text for portability.
  metadata       String?
  createdAt      DateTime     @default(now())

  @@index([operatorUserId])
  @@index([organizationId])
  @@index([action, createdAt])
  @@index([createdAt])
}
